# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Football-Data.org
FOOTBALL_DATA_API_KEY=

# API-Football (api-football.com — free tier 100 req/jour) — source secondaire pour
# combler les gaps de Football-Data (lineups, match stats, player stats).
API_FOOTBALL_KEY=

# OpenAI
OPENAI_API_KEY=

# Resend
RESEND_API_KEY=

# Cron (protection des endpoints /api/cron/*)
CRON_SECRET=

# Sentry (monitoring d'erreurs ; vide = désactivé silencieusement)
NEXT_PUBLIC_SENTRY_DSN=

# URL publique du site (sans slash final). Si vide, fallback sur le sous-domaine
# Vercel `https://tactua.vercel.app`. À renseigner avec `https://tactuo.com`
# une fois le domaine custom configuré dans Vercel.
NEXT_PUBLIC_SITE_URL=
